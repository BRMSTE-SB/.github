{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://brmste.com/substrate/domains/registry.schema.json",
  "title": "BRMSTE multi-cloud domain registry",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "version", "expected_total", "known_apexes", "policy", "clouds", "domains"],
  "properties": {
    "schema": { "const": "brmste-domain-registry/v2" },
    "version": { "type": "string", "minLength": 1 },
    "expected_total": { "type": "integer", "minimum": 1 },
    "known_apexes": { "type": "integer", "minimum": 1 },
    "policy": {
      "type": "object",
      "required": ["target_hsts", "required_headers", "forbidden_headers"],
      "properties": {
        "https_only": { "type": "boolean" },
        "target_hsts": { "type": "string", "pattern": "^max-age=[0-9]+" },
        "required_headers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "forbidden_headers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "header_source": { "type": "string" }
      }
    },
    "clouds": {
      "type": "object",
      "required": ["cloudflare", "hetzner", "aws", "azure", "siemens_iem"],
      "properties": {
        "cloudflare": { "type": "string" },
        "hetzner": { "type": "string" },
        "aws": { "type": "string" },
        "azure": { "type": "string" },
        "siemens_iem": { "type": "string" }
      }
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "apex", "role", "external", "clouds", "expected"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "apex": { "type": "string", "pattern": "^[a-z0-9.-]+\\.[a-z]{2,}$" },
          "role": { "type": "string", "minLength": 1 },
          "external": { "type": "boolean" },
          "clouds": {
            "type": "object",
            "required": ["cloudflare", "hetzner", "aws", "azure", "siemens_iem"],
            "properties": {
              "cloudflare": { "type": ["object", "null"] },
              "hetzner": { "type": ["object", "null"] },
              "aws": { "type": ["object", "null"] },
              "azure": { "type": ["object", "null"] },
              "siemens_iem": { "type": ["object", "null"] }
            }
          },
          "expected": {
            "type": "object",
            "required": ["https", "hsts", "managed_headers"],
            "properties": {
              "https": { "type": "boolean" },
              "hsts": { "type": "string", "minLength": 1 },
              "managed_headers": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
