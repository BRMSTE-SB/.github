{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/BRMSTE-SB/.github/blob/main/domains/registry.schema.json",
  "title": "BRMSTE Multi-Cloud Domains Registry",
  "type": "object",
  "required": ["_meta", "domains"],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["schema", "owner", "cloudflare_account_id", "expected_total", "roles", "clouds"],
      "properties": {
        "schema": { "type": "string", "const": "brmste-domains-registry/v1" },
        "owner": { "type": "string" },
        "cloudflare_account_id": { "type": "string" },
        "expected_total": { "type": "integer", "minimum": 1 },
        "roles": {
          "type": "array",
          "items": { "type": "string", "enum": ["primary", "carbon_justice", "coming_soon", "redirect"] }
        },
        "clouds": {
          "type": "object",
          "required": ["cloudflare", "hetzner", "aws", "azure", "siemens_iem"],
          "properties": {
            "cloudflare": { "type": "object" },
            "hetzner": { "type": "object" },
            "aws": { "type": "object" },
            "azure": { "type": "object" },
            "siemens_iem": { "type": "object" }
          }
        }
      }
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["domain", "role", "clouds"],
        "properties": {
          "domain": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]*[a-z0-9])?)+$"
          },
          "role": { "type": "string", "enum": ["primary", "carbon_justice", "coming_soon", "redirect"] },
          "source": { "type": "string", "enum": ["known", "cloudflare-sync"] },
          "zone_id": { "type": ["string", "null"] },
          "redirect_to": { "type": ["string", "null"] },
          "hsts_preload": { "type": "boolean" },
          "clouds": {
            "type": "object",
            "required": ["cloudflare", "hetzner", "aws", "azure", "siemens_iem"],
            "properties": {
              "cloudflare": { "type": "string" },
              "hetzner": { "type": "string" },
              "aws": { "type": "string" },
              "azure": { "type": "string" },
              "siemens_iem": { "type": "string" }
            }
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  }
}
