{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/BRMSTE-SB/.github/blob/main/domains/registry.schema.json",
  "title": "BRMSTE multi-cloud domain registry",
  "type": "object",
  "required": ["_meta", "clouds", "lanes", "domains"],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["schema", "expected_total", "known_apexes", "clouds", "cloudflare_account"],
      "properties": {
        "schema": { "type": "string", "const": "brmste-domain-registry/v2" },
        "expected_total": { "type": "integer", "minimum": 1 },
        "known_apexes": { "type": "integer", "minimum": 1 },
        "cloudflare_account": { "type": "string", "minLength": 8 },
        "worker": { "type": "string" },
        "health_token": { "type": "string" },
        "clouds": {
          "type": "array",
          "items": { "enum": ["cloudflare", "hetzner", "aws", "azure", "siemens_iem"] }
        }
      }
    },
    "clouds": {
      "type": "object",
      "required": ["cloudflare", "hetzner", "aws", "azure", "siemens_iem"],
      "additionalProperties": { "type": "object" }
    },
    "lanes": { "type": "object" },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "domain", "lane", "clouds", "audit", "expected"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "domain": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]*[a-z0-9])?)+$"
          },
          "apex": { "type": "boolean" },
          "lane": { "enum": ["primary", "commercial", "carbon_justice", "portfolio", "brand"] },
          "role": { "type": "string" },
          "clouds": {
            "type": "object",
            "required": ["cloudflare", "hetzner", "aws", "azure", "siemens_iem"],
            "properties": {
              "cloudflare": {
                "type": "object",
                "required": ["zone", "worker_route", "role"],
                "properties": {
                  "zone": { "type": "boolean" },
                  "worker_route": { "type": "boolean" },
                  "role": { "type": "string" }
                }
              },
              "hetzner": { "type": ["string", "null"] },
              "aws": { "type": "boolean" },
              "azure": { "type": "boolean" },
              "siemens_iem": { "type": "boolean" }
            }
          },
          "audit": { "type": "boolean" },
          "expected": {
            "type": "object",
            "required": ["https", "hsts", "worker_headers"],
            "properties": {
              "https": { "type": "boolean" },
              "hsts": { "type": "boolean" },
              "worker_headers": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
