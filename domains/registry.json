  "policy": {
    "target_hsts": "max-age=63072000; includeSubDomains; preload",
    "required_headers": [
      "strict-transport-security",
      "x-content-type-options",
      "x-frame-options",
      "referrer-policy",
      "permissions-policy",
      "content-security-policy"
    ],
    "forbidden_headers": [
      "x-powered-by",
      "x-middleware-rewrite",
      "x-aspnet-version",
      "x-aspnetmvc-version",
      "x-runtime"
    ],
    "note": "required_headers must appear on EVERY response including redirects. forbidden_headers leak stack/internal topology (e.g. x-middleware-rewrite exposing an internal localhost origin) and must be stripped at the edge/platform."
  },
