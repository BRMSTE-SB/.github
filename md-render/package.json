{
  "name": "brmste-md-render",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "BRMSTE branded Markdown render — Hetzner origin nodes behind Cloudflare with HSTS",
  "scripts": {
    "build": "node build.mjs",
    "serve": "node serve.mjs",
    "start": "node build.mjs && node serve.mjs",
    "deploy": "npm run build && wrangler deploy",
    "deploy:dry": "npm run build && wrangler deploy --dry-run",
    "test": "vitest run"
  },
  "dependencies": {
    "marked": "^14.1.3"
  },
  "devDependencies": {
    "vitest": "^4.1.9",
    "wrangler": "^4.0.0"
  }
}
