# Per-node config for the mempool + LND stack. Copy to node.env on each server.
# BRMSTE LTD · CH 15310393 · GB2607860 — secrets NEVER committed; keep node.env out of git.
BITCOIN_NETWORK=main
BITCOIN_RPC_USER=brmste
BITCOIN_RPC_PASS=__set_on_node__
MEMPOOL_DB_PASS=__set_on_node__
MEMPOOL_DB_ROOT_PASS=__set_on_node__
LND_ALIAS=brmste-<node-id>
# Bind to 127.0.0.1 and reverse-proxy behind the edge; only open publicly behind auth.
MEMPOOL_BIND=127.0.0.1
LND_BIND=127.0.0.1
